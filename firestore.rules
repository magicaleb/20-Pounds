rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Personal app model:
    // Store user data under /users/{uid}/... and allow only that uid.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Subcollections such as /users/{uid}/entries/{entryId}
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
